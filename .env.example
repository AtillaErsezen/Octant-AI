# ──────────────────────────────────────────────────────────────
# Octant AI — Environment Variables Template
# Copy to .env and fill in your values:  cp .env.example .env
# ──────────────────────────────────────────────────────────────

# ── API Keys (required) ───────────────────────────────────────
GEMINI_API_KEY=your-google-gemini-api-key
RESON8_API_KEY=your-reson8-api-key-from-console.reson8.dev
FAL_API_KEY=your-fal-ai-api-key
DUST_API_KEY=your-dust-tt-api-key
OPENBB_TOKEN=your-openbb-personal-access-token

# ── API Keys (optional) ──────────────────────────────────────
CORE_API_KEY=your-core-ac-uk-api-key

# ── File Paths ────────────────────────────────────────────────
CHROMA_DB_PATH=./data/chromadb
REPORTS_OUTPUT_PATH=./reports
LATEX_TEMPLATES_PATH=./latex_templates
WSBT_BINARY_PATH=./bin/wsbt

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Server ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
HOST=0.0.0.0
PORT=8000

# ── Optional: Redis (production session store) ────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Pipeline Tuneables ────────────────────────────────────────
MAX_UNIVERSE_SIZE=200
BACKTEST_DEFAULT_PERIOD_YEARS=10
MONTE_CARLO_PATHS=50000

# ── Model Names ───────────────────────────────────────────────
GEMINI_REASONING_MODEL=gemini-2.5-pro-preview-05-06
GEMINI_FLASH_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ── External Service URLs ─────────────────────────────────────
RESON8_BASE_URL=https://api.reson8.dev
FAL_BASE_URL=https://api.fal.ai
