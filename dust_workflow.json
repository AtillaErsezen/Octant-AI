{
  "workflow_name": "octant_pipeline",
  "version": "1.0.0",
  "description": "5-stage concurrent agentic financial pipeline execution",
  "config": {
    "retry_policy": {
      "max_attempts": 3,
      "backoff": "exponential",
      "initial_interval_ms": 1000
    }
  },
  "nodes": [
    {
      "id": "A1",
      "name": "Hypothesis Engine",
      "type": "action",
      "timeout": 60,
      "input_schema": {
        "audio_bin": "bytes",
        "thesis_text": "string"
      },
      "output_schema": {
        "hypotheses": "list[HypothesisObject]"
      }
    },
    {
      "id": "A2",
      "name": "Literature Agent",
      "type": "action",
      "timeout": 300,
      "depends_on": ["A1"],
      "input_schema": {
        "hypotheses": "list[HypothesisObject]"
      },
      "output_schema": {
        "citations_db": "dict[str, list]"
      }
    },
    {
      "id": "A3",
      "name": "Universe Builder",
      "type": "action",
      "timeout": 300,
      "depends_on": ["A1"],
      "input_schema": {
        "hypotheses": "list[HypothesisObject]",
        "exchanges": "list[str]",
        "sector": "string",
        "time_range": "list[str]"
      },
      "output_schema": {
        "universe_result": "UniverseBuildResult"
      }
    },
    {
      "id": "A4",
      "name": "Backtesting Engine",
      "type": "action",
      "timeout": 600,
      "depends_on": ["A2", "A3"],
      "input_schema": {
        "universe_result": "UniverseBuildResult",
        "hypotheses": "list[HypothesisObject]",
        "citations_db": "dict[str, list]"
      },
      "output_schema": {
        "results_manifest": "dict[str, PerformanceReport]"
      }
    },
    {
      "id": "A5",
      "name": "Report Architect",
      "type": "action",
      "timeout": 300,
      "depends_on": ["A4"],
      "input_schema": {
        "hypotheses": "list[HypothesisObject]",
        "citations_db": "dict[str, list]",
        "results_manifest": "dict[str, PerformanceReport]"
      },
      "output_schema": {
        "pdf_path": "string"
      }
    }
  ]
}
